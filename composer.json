{
    "name": "everypay/payment-gateway",
    "description": "Payment gateway service",
    "type": "project",
    "require" : {
        "php": "^8.2"
    },
    "require-dev": { 
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "./vendor/bin/phpunit --configuration phpunit.xml"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}