# Application
APP_ENV=production

# Database
DB_HOST=mysql
DB_PORT=3306
DB_NAME=everypay
DB_USER=everypay
DB_PASS=secret

# Mailer (Symfony Mailer DSN)
# For local dev with Mailpit: smtp://mailpit:1025
# For production SMTP: smtp://user:pass@smtp.example.com:587
MAILER_DSN=smtp://mailpit:1025

# Mail sender
MAIL_FROM_ADDRESS=noreply@everypay.test
MAIL_FROM_NAME=EveryPay
